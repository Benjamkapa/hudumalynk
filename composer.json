{
    "name": "hudumalynk/platform",
    "description": "HudumaLynk Digital Marketplace — Connecting service providers and product vendors with customers across Nairobi",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4",
        "yiisoft/yii2": "~2.0.45",
        "yiisoft/yii2-bootstrap5": "~2.0.0",
        "yiisoft/yii2-swiftmailer": "~2.1.0",
        "kartik-v/yii2-widget-fileinput": "*",
        "kartik-v/yii2-grid": "*",
        "kartik-v/yii2-date-range": "*",
        "vlucas/phpdotenv": "^5.4"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0"
    },
    "autoload": {
        "psr-4": {
            "common\\": "common/",
            "frontend\\": "frontend/",
            "backend\\": "backend/",
            "console\\": "console/"
        }
    },
    "config": {
        "process-timeout": 1800,
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "composer/installers": true
        }
    },
    "extra": {
        "asset-installer-paths": {
            "npm-asset-library": "vendor/npm-asset",
            "bower-asset-library": "vendor/bower-asset"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
