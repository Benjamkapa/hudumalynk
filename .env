# ================================================================
#  HudumaLynk — Environment Configuration
#  Copy this file to .env and fill in your values
# ================================================================

APP_NAME=HudumaLynk
APP_ENV=development
APP_DEBUG=true
APP_KEY=hudumalynk-local-dev-secret-key-1

# ── Admin Credentials ─────────────────────────────────────────────
ADMIN_FIRST_NAME=Okombe
ADMIN_LAST_NAME=Mabenjo
ADMIN_EMAIL=admin@hudumalynk.co.ke
ADMIN_PHONE=+254790590653
ADMIN_PASSWORD=Admin@123

# ── Database ─────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=hudumalynk
DB_USER=root
DB_PASS=fortjesus

# ── Frontend / Backend URLs ───────────────────────────────────────
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8081

# ── M-Pesa Daraja API (Sandbox) ───────────────────────────────────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://yourdomain.ngrok-free.app/order/mpesa-callback
MPESA_ACCOUNT_REF=HudumaLynk

# ── Currency ──────────────────────────────────────────────────────
# Default exchange rate (KES per 1 USD) — update daily via cron or live API
KES_TO_USD_RATE=0.0077
CURRENCY_API_KEY=

# ── SMS Provider (pluggable — configure the active one) ───────────
SMS_PROVIDER=africastalking
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_at_api_key
AFRICASTALKING_SENDER_ID=HudumaLynk

# ── Email (SMTP) ─────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@hudumalynk.com
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME=HudumaLynk
MAIL_FROM_ADDRESS=noreply@hudumalynk.com

# ── Flutterwave (Card Payments) ───────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxx
FLUTTERWAVE_REDIRECT_URL=http://localhost:8080/order/payment-callback

# ── Upload ────────────────────────────────────────────────────────
UPLOAD_PATH=frontend/web/uploads
UPLOAD_MAX_SIZE=5242880

EMA